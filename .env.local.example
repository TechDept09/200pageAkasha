# =====================================================================
# Public (exposed to the browser via Next.js NEXT_PUBLIC_ prefix)
# Safe to commit values for: they appear in client bundles anyway.
# =====================================================================

# --- Wix Headless OAuth client ---
# Wix Dashboard, Settings, Headless Settings, OAuth apps, Create OAuth app.
# Copy the "Client ID" only (not the secret, we use visitor / OAuth flow).
NEXT_PUBLIC_WIX_CLIENT_ID=your-wix-headless-client-id

# --- Wix Stores product IDs per course + plan ---
# Wix Dashboard, Catalog, Products, click the product, copy the UUID from the URL.
NEXT_PUBLIC_WIX_PRODUCT_ID=your-200h-essential-product-id
NEXT_PUBLIC_WIX_PRODUCT_ID_PREMIUM=your-200h-premium-full-product-id
NEXT_PUBLIC_WIX_PRODUCT_ID_PREMIUM_INSTALLMENT=your-200h-premium-installment-product-id
NEXT_PUBLIC_WIX_PRODUCT_ID_300H_FULL=your-300h-full-product-id
NEXT_PUBLIC_WIX_PRODUCT_ID_300H_INSTALLMENT=your-300h-installment-product-id
NEXT_PUBLIC_WIX_PRODUCT_ID_80H_YIN_FULL=your-80h-yin-full-product-id
NEXT_PUBLIC_WIX_PRODUCT_ID_80H_YIN_INSTALLMENT=your-80h-yin-installment-product-id
NEXT_PUBLIC_WIX_PRODUCT_ID_80H_HATHA_FULL=your-80h-hatha-full-product-id
NEXT_PUBLIC_WIX_PRODUCT_ID_80H_HATHA_INSTALLMENT=your-80h-hatha-installment-product-id
NEXT_PUBLIC_WIX_PRODUCT_ID_80H_MEDITATION_FULL=your-80h-meditation-full-product-id
NEXT_PUBLIC_WIX_PRODUCT_ID_80H_MEDITATION_INSTALLMENT=your-80h-meditation-installment-product-id
NEXT_PUBLIC_WIX_PRODUCT_ID_FEMININE=your-feminine-wisdom-product-id
NEXT_PUBLIC_WIX_PRODUCT_ID_KUNDALINI_FULL=your-kundalini-india-full-product-id
NEXT_PUBLIC_WIX_PRODUCT_ID_KUNDALINI_INSTALLMENT=your-kundalini-india-installment-product-id

# --- Marketing pixel + analytics IDs (intentionally public) ---
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA_ID=


# =====================================================================
# Server-only secrets. NEVER prefix these with NEXT_PUBLIC_,
# they would leak into the client bundle. Set them in Vercel,
# never commit values.
# =====================================================================

# --- Meta Conversions API token ---
# Meta Events Manager, your Pixel, Settings, Conversions API, Generate access token.
# Used by /api/meta-purchase to relay server-side Purchase events.
META_CAPI_TOKEN=
META_PIXEL_ID=

# --- Wix Automations webhook signing secret ---
# Wix Dashboard, Automations, your "Order Paid" automation, Webhook action,
# copy the signing secret. If this is unset, /api/meta-purchase will refuse
# every request (fail closed). Anyone hitting the endpoint without a valid
# HMAC signature would otherwise be able to inject fake Purchase events,
# burn Meta CAPI quota, and corrupt attribution.
WIX_WEBHOOK_SECRET=

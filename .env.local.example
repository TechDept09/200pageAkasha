# --- Wix Headless ---
# Get from Wix Dashboard → Settings → Headless Settings → OAuth apps → Create OAuth app
# Copy the "Client ID" (NOT the secret — we use visitor/OAuth flow, no secret needed)
NEXT_PUBLIC_WIX_CLIENT_ID=your-wix-headless-client-id

# Wix Stores product ID for the 200-Hour YTT course
# Get from Wix Dashboard → Catalog → Products → click your product → URL contains the ID
# (looks like a UUID, e.g. 11111111-2222-3333-4444-555555555555)
NEXT_PUBLIC_WIX_PRODUCT_ID=your-wix-stores-product-id
